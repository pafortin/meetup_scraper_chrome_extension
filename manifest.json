{
  "manifest_version": 3,
  "name": "Meetup Scraper 2026",
  "version": "2.0",
  "description": "Exporte en CSV tous les participants des événements passés d'un groupe Meetup (events récupérés automatiquement, CSV enrichi).",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.meetup.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "128": "icon192.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "128": "icon192.png"
  }
}
