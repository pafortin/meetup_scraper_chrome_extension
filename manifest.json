{
  "manifest_version": 3,
  "name": "Meetup Scraper 2026",
  "version": "1.2",
  "description": "Exporte les participants d'un événement Meetup en CSV.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.meetup.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "128": "icon192.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "128": "icon192.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.meetup.com/*"],
      "js": ["content.js"]
    }
  ]
}